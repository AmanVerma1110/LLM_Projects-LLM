    },
    {
      "parameters": {
        "jsCode": "const cookieData = 'overleaf_session2=s%3AVMjQO_IjTz0SUVdOKMbVPNQ93fQYZbcg.7kLHk35B8hZngWWe6V0ngGQjwzPhE2GU%2BgG72Nb0%2Fwg'; // Keep your massive cookie string here!\nconst decodedCookie = decodeURIComponent(cookieData);\n\nconst latex = $input.first().json.latexCode;\n// Convert LaTeX to Base64 so Overleaf can ingest it safely\nconst base64Latex = Buffer.from(latex).toString('base64');\n\nreturn [{ json: { cookie: decodedCookie, latexCode: latex, base64Latex: base64Latex } }];"
      },
      "id": "3dfaf9ed-5a02-45dd-9e7c-2da74a0b193e",
      "name": "Decode Cookie key",
      "type": "n8n-nodes-base.code",
