    {
      "parameters": {
        "jsCode": "const htmlString = $input.first().json.data; \n\n// This smarter regex looks specifically for Overleaf's custom 'ol-csrfToken' tag, \n// as well as a few other common hiding spots just in case!\nconst match = htmlString.match(/name=\"ol-csrfToken\"\\s+content=\"([^\"]+)\"/) \n           || htmlString.match(/name=\"csrf-token\"\\s+content=\"([^\"]+)\"/)\n           || htmlString.match(/window\\.csrfToken\\s*=\\s*\"([^\"]+)\"/);\n\nlet csrfToken = \"TOKEN_NOT_FOUND\";\n\nif (match && match[1]) {\n  csrfToken = match[1];\n} \n\nreturn {\n  json: {\n    csrfToken: csrfToken,\n    cookie: $input.first().json.cookie,\n    latexCode: $input.first().json.latexCode\n  }\n};"
      },
      "id": "f90ae93c-628f-402b-8dba-b90accfb85d7",
      "name": "Extract csrf",
