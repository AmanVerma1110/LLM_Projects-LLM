    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze this job description and current resume, then create an optimized resume tailored to the position.\n\nJob Description:\n{{ $json.jobDescription }}\n\nCurrent Resume:\n{{ $json.currentResume }}",
        "options": {
          "systemMessage": "You are a professional resume writer. Analyze the job description and current resume, then create an optimized resume that highlights relevant skills and experience for the position."
        }
      },
      "id": "3e4e20ef-6749-4f56-8cd8-b98f77a53bcf",
      "name": "Resume Generator",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        400,
        320
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Convert this resume content into a professional LaTeX document. Output ONLY valid LaTeX code that can be compiled directly, with no explanations or markdown formatting.\n\nResume Content:\n{{ $json.output }}",
        "options": {
          "systemMessage": "You are a LaTeX expert. Convert resume content into clean, professional LaTeX code using appropriate document classes and formatting. Output only the LaTeX code without any explanations."
        }
      },
      "id": "3878931f-b2b3-4383-9d8a-d4d9ff5f2704",
      "name": "Resume Latex Convertor",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        400,
        528
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json.output;\n\nlet latexCode = response;\n\nlatexCode = latexCode.replace(/^```latex\\n?/gm, '');\nlatexCode = latexCode.replace(/^```\\n?/gm, '');\nlatexCode = latexCode.replace(/\\n?```$/gm, '');\n\nconst docClassMatch = latexCode.match(/\\\\documentclass/);\nif (docClassMatch) {\n  latexCode = latexCode.substring(latexCode.indexOf('\\\\documentclass'));\n}\n\nconst endDocMatch = latexCode.match(/\\\\end{document}/);\nif (endDocMatch) {\n  const endIndex = latexCode.indexOf('\\\\end{document}') + '\\\\end{document}'.length;\n  latexCode = latexCode.substring(0, endIndex);\n}\n\nlatexCode = latexCode.trim();\n\nreturn [{ json: { latexCode } }];"
      },
      "id": "dca5f2a6-f847-47ed-8f08-cb597691f6eb",
      "name": "Code in JavaScript",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        896,
        240
      ]
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "1",
              "name": "processedLatex",
              "value": "={{ $json.latexCode }}",
              "type": "string"
            }
          ]
        },
        "includeOtherFields": true,
        "options": {}
      },
      "id": "86dba204-5b3f-4531-850a-00b33a038308",
      "name": "Edit Fields3 manual",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
