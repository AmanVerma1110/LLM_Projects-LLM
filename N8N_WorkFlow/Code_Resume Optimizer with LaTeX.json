    {
      "parameters": {
        "jsCode": "const compileResponse = $input.first().json;\nconst projectId = $('Extract Project ID').item.json.projectId;\nconst pdfUrl = compileResponse.pdfUrl || '/project/' + projectId + '/output/output.pdf';\nconst cookie = $('Extract Project ID').item.json.cookie;\n\nreturn [{ json: { pdfUrl, cookie, projectId } }];"
      },
