    {
      "parameters": {
        "jsCode": "// The previous node already did the hard work and gave us the ID directly!\nconst projectId = $input.first().json.projectId;\n\n// Grab your security tokens from the earlier node to keep the chain intact\nconst cookie = $('Extract csrf').item.json.cookie;\nconst csrfToken = $('Extract csrf').item.json.csrfToken;\n\nreturn [{ json: { projectId: projectId, cookie: cookie, csrfToken: csrfToken } }];"
      },
